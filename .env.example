# ВНИМАНИЕ (прод): при DEBUG=False приложение не запустится с этим дефолтным
# ключом — задайте собственный SECRET_KEY и реальные ALLOWED_HOSTS.
# При DEBUG=False автоматически включаются HTTPS-only cookie/redirect/HSTS.
SECRET_KEY=dev-insecure-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# venv-dev: PostgreSQL в контейнере на порту 5433 (см. docker-compose.yml).
# Сервисы web/qcluster в compose переопределяют это на db:5432 (внутренняя сеть).
DATABASE_URL=postgres://lawiot:lawiot@localhost:5433/lawiot
# План 3c: cron ежедневного обхода целей авто-приёма (по умолчанию 03:00).
SWEEP_CRON=0 3 * * *
# Cron ежедневного обнаружения новых актов на портале (по умолчанию 04:00).
DISCOVERY_CRON=0 4 * * *
# Прод за обратным прокси: домены для CSRF со схемой, через запятую,
# напр. CSRF_TRUSTED_ORIGINS=https://lawiot.ru,https://www.lawiot.ru
# Если не задано — выводится из ALLOWED_HOSTS. В dev (DEBUG=True) не используется.
# CSRF_TRUSTED_ORIGINS=
